{
  "name": "quota-gem",
  "version": "1.1.1",
  "description": "Windows tray utility for unified Codex and Claude usage visibility under the QuotaGem brand.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "package": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.gyozalab.quotagem",
    "productName": "QuotaGem",
    "copyright": "Copyright © 2025 gyozalab",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@ccusage/**/*"
    ],
    "extraResources": [
      {
        "from": "public/tray-icon-runtime.png",
        "to": "tray-icon-runtime.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/quota-gem-app-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "keywords": [
    "electron",
    "tray",
    "windows",
    "claude",
    "codex",
    "usage",
    "quota",
    "react",
    "typescript"
  ],
  "author": "gyozalab",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "ccusage": "^20.0.14",
    "chart.js": "^4.5.0",
    "electron-store": "^11.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
